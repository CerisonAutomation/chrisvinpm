rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check for admin role
    function isAdmin() {
      return request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.admin == true);
    }

    // Helper to check for editor role
    function isEditor() {
      return request.auth != null && (request.auth.token.role == 'editor' || isAdmin());
    }

    // CMS Pages
    match /pages/{pageId} {
      allow read: if resource.data.status == 'published';
      allow read, write: if isEditor();
    }

    // Global Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fallback
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
